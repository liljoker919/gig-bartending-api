# =============================================================================
# Gig Bartending App - Environment Configuration
# =============================================================================
# Copy this file to .env and update the values for your local environment:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env files to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Web Application (React + Vite)
# -----------------------------------------------------------------------------

# API base URL for the web application
# Development: http://localhost:5000
# Production: https://api.gigbartending.com
VITE_API_BASE_URL=http://localhost:5000

# Web application port (default: 3000)
VITE_PORT=3000

# Node environment (development, production, test)
NODE_ENV=development

# -----------------------------------------------------------------------------
# Mobile Application (React Native + Expo)
# -----------------------------------------------------------------------------

# API base URL for the mobile application
# Development: Use your local IP address (e.g., http://192.168.1.100:5000)
# Production: https://api.gigbartending.com
EXPO_PUBLIC_API_BASE_URL=http://localhost:5000

# -----------------------------------------------------------------------------
# API Backend (.NET 8 Web API)
# -----------------------------------------------------------------------------

# ASP.NET Core environment (Development, Staging, Production)
ASPNETCORE_ENVIRONMENT=Development

# API application URLs (semicolon-separated for multiple URLs)
ASPNETCORE_URLS=http://localhost:5000

# Database connection string
# Example for SQL Server: Server=localhost;Database=GigBartending;User Id=sa;Password=YourPassword;TrustServerCertificate=true
# Example for PostgreSQL: Host=localhost;Database=GigBartending;Username=postgres;Password=YourPassword
# Example for SQLite: Data Source=gigbartending.db
DATABASE_CONNECTION_STRING=Data Source=gigbartending.db

# JWT Authentication settings
JWT_SECRET=your-secret-key-change-in-production-min-32-characters
JWT_ISSUER=GigBartendingApp
JWT_AUDIENCE=GigBartendingApp
JWT_EXPIRY_MINUTES=60

# CORS allowed origins (comma-separated list)
# For local development, include your web and mobile app URLs
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006

# -----------------------------------------------------------------------------
# Optional: Third-Party Services
# -----------------------------------------------------------------------------

# Email service configuration (for future notifications)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-email-password
# SMTP_FROM_EMAIL=noreply@gigbartending.com
# SMTP_FROM_NAME=Gig Bartending App

# Cloud storage (for future profile photos)
# STORAGE_PROVIDER=local
# STORAGE_BUCKET=gigbartending-uploads
# STORAGE_ACCESS_KEY=your-access-key
# STORAGE_SECRET_KEY=your-secret-key

# Analytics / Monitoring (for future use)
# SENTRY_DSN=https://your-sentry-dsn
# GOOGLE_ANALYTICS_ID=UA-XXXXX-Y

# -----------------------------------------------------------------------------
# Development Tools
# -----------------------------------------------------------------------------

# Logging level (Trace, Debug, Information, Warning, Error, Critical)
LOG_LEVEL=Information

# Enable Swagger UI in development (true/false)
ENABLE_SWAGGER=true

# Enable detailed error messages (development only)
DETAILED_ERRORS=true
