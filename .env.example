# =============================================================================
# Gig Bartending API - Environment Configuration
# =============================================================================
# Copy this file to .env and update the values for your local environment:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env files to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# API Backend (.NET 8 Web API)
# -----------------------------------------------------------------------------

# ASP.NET Core environment (Development, Staging, Production)
ASPNETCORE_ENVIRONMENT=Development

# API application URLs (semicolon-separated for multiple URLs)
ASPNETCORE_URLS=http://localhost:5000

# Database connection string
# Use the same password value you set in SQLSERVER_SA_PASSWORD below to avoid mismatches.
# For local Docker SQL Server: Server=localhost,1433;Database=GigBartending;User Id=sa;Password=<SET_A_STRONG_PASSWORD>;TrustServerCertificate=true
# Example for PostgreSQL: Host=localhost;Database=GigBartending;Username=postgres;Password=YourPassword
# Example for SQLite: Data Source=gigbartending.db
DATABASE_CONNECTION_STRING=Server=localhost,1433;Database=GigBartending;User Id=sa;Password=<SET_A_STRONG_PASSWORD>;TrustServerCertificate=true

# SQL Server Docker Configuration
# SA password must be at least 8 characters and contain uppercase, lowercase, digits, and symbols
# This is used by docker-compose.yml for the SQL Server container
SQLSERVER_SA_PASSWORD=

# JWT Authentication settings
# IMPORTANT: Use a strong random string (64+ characters recommended)
# Generate with: openssl rand -base64 64 | tr -d '\n'
JWT_SECRET=your-secret-key-change-in-production-use-minimum-64-characters-for-better-security
JWT_ISSUER=GigBartendingApp
JWT_AUDIENCE=GigBartendingApp
JWT_EXPIRY_MINUTES=60

# CORS allowed origins (comma-separated list)
# For local development, include the front-end app URLs that will call the API
CORS_ALLOWED_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Optional: Third-Party Services
# -----------------------------------------------------------------------------

# Email service configuration (for future notifications)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-email-password
# SMTP_FROM_EMAIL=noreply@gigbartending.com
# SMTP_FROM_NAME=Gig Bartending App

# Cloud storage (for future profile photos)
# STORAGE_PROVIDER=local
# STORAGE_BUCKET=gigbartending-uploads
# STORAGE_ACCESS_KEY=your-access-key
# STORAGE_SECRET_KEY=your-secret-key

# Analytics / Monitoring (for future use)
# SENTRY_DSN=https://your-sentry-dsn
# GOOGLE_ANALYTICS_ID=UA-XXXXX-Y

# -----------------------------------------------------------------------------
# Development Tools
# -----------------------------------------------------------------------------

# Logging level (Trace, Debug, Information, Warning, Error, Critical)
LOG_LEVEL=Information

# Enable Swagger UI in development (true/false)
ENABLE_SWAGGER=true

# Enable detailed error messages (development only)
DETAILED_ERRORS=true
