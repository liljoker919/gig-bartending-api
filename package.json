{
  "name": "gig-bartending-app",
  "version": "1.0.0",
  "private": true,
  "description": "A cross-platform app that connects bartenders with open shifts",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "mobile": "npm run start --workspace=@gig-bartending/mobile",
    "web": "npm run dev --workspace=@gig-bartending/web",
    "api": "cd services/api/GigBartending.Api && dotnet run",
    "api:build": "cd services/api && dotnet build",
    "api:test": "cd services/api && dotnet test",
    "build:web": "npm run build --workspace=@gig-bartending/web",
    "lint": "npm run lint --workspaces --if-present",
    "type-check": "npm run type-check --workspaces --if-present",
    "db:reset": "cd services/api && bash db-reset.sh",
    "db:migrate": "cd services/api && bash db-migrate.sh",
    "db:seed": "cd services/api && bash db-seed.sh"
  },
  "keywords": [
    "bartending",
    "gig-work",
    "shifts",
    "react-native",
    "react"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  }
}
